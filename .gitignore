# ============================================================
# HuiYuYuan root .gitignore
# ============================================================

# Temporary / scratch files
tmp_*.txt
analyze*.txt
tmp_*.py
test_*.py
/.tmp_*.sql
/add_test_product.sql
/check_*.sh
/debug_*.sh
/get_full_nginx.sh
/list_routes.sh
/query_test_product.sh
/test_*.sh
/tmp_*.sqlite
/release_artifacts/
/scripts/add_download_route.sh

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.iml
*.swp
*.swo
*~

# Environment files
.env
.env.*
!.env.example

# Sensitive files
secrets.dart
**/key.properties
**/local.properties
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore

# Python cache
__pycache__/
*.pyc
*.pyo

# Deployment logs
deploy_*.log

# Build artifacts
builds/*.apk
builds/*.aab
builds/migration/

# Agent-generated local directories
.agent/
CLAUDE.md
huiyuyuan_app/.vscode/

# Local test outputs
issue_stats.txt
login_test_result.txt
test_output.txt

# Python virtual environments
.venv/
venv/

# Flutter build directories
**/.gradle/
**/.kotlin/
**/*.iml
**/GeneratedPluginRegistrant.*
**/Flutter/Generated.xcconfig
**/Flutter/ephemeral/
**/Flutter/flutter_export_environment.sh
huiyuyuan_app/build/
huiyuyuan_app/.dart_tool/
huiyuyuan_app/.flutter-plugins
huiyuyuan_app/.flutter-plugins-dependencies
huiyuyuan_app/.packages

# Database backups
*.sql.gz
backups/

# Uploads
uploads/

# Screenshots / visual acceptance artefacts (moved to docs/screenshots/)
# Only root-level screenshot PNGs are excluded; app assets under
# huiyuyuan_app/ remain tracked normally.
/docs/screenshots/
/coord-search/
/final_acceptance_screens/
# Root-level screenshot image files (not app assets)
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.gif
