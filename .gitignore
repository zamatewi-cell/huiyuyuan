# ============================================================
# HuiYuYuan root .gitignore
# ============================================================

# Temporary / scratch files
tmp_*.txt
analyze*.txt
tmp_*.py
test_*.py

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.iml
*.swp
*.swo
*~

# Environment files
.env
.env.*
!.env.example

# Sensitive files
secrets.dart
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore

# Python cache
__pycache__/
*.pyc
*.pyo

# Deployment logs
deploy_*.log

# Build artifacts
builds/*.apk
builds/*.aab
builds/migration/

# Agent-generated local directories
.agent/
CLAUDE.md
huiyuyuan_app/.vscode/

# Local test outputs
issue_stats.txt
login_test_result.txt
test_output.txt

# Python virtual environments
.venv/
venv/

# Flutter build directories
huiyuyuan_app/build/
huiyuyuan_app/.dart_tool/
huiyuyuan_app/.flutter-plugins
huiyuyuan_app/.flutter-plugins-dependencies
huiyuyuan_app/.packages

# Database backups
*.sql.gz
backups/

# Uploads
uploads/
