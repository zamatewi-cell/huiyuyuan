# 汇玉源后端 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ?? .env 文件不要提交到 Git！

# ============ 数据库 ============
DATABASE_URL=postgresql://huyy_user:YOUR_PASSWORD_HERE@localhost:5432/huiyuanyuan

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT 密钥（生产环境务必换成随机256位字符串）============
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ============ 阿里云短信（申请完后填入）============
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=汇玉源
SMS_TEMPLATE_CODE=

# ============ 阿里云 OSS（后续任务B用）============
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=huiyuanyuan-images
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# ============ 应用配置 ============
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=*
