/// 汇玉源 - 敏感配置示例文件
/// 
/// 使用说明：
/// 1. 复制此文件为 secrets.dart
/// 2. 填入真实的API密钥
/// 3. 确保 secrets.dart 已添加到 .gitignore
library;

/// 敏感配置类
/// 请勿将实际密钥提交到版本控制
class Secrets {
  // ============ DeepSeek AI ============
  
  /// DeepSeek API Key
  /// 获取方式: https://platform.deepseek.com/api_keys
  static const String deepseekApiKey = 'YOUR_DEEPSEEK_API_KEY';
  
  // ============ 阿里云 OSS ============
  
  /// OSS AccessKey ID
  static const String ossAccessKeyId = 'YOUR_OSS_ACCESS_KEY_ID';
  
  /// OSS AccessKey Secret
  static const String ossAccessKeySecret = 'YOUR_OSS_ACCESS_KEY_SECRET';
  
  // ============ Google Gemini ============
  
  /// Gemini API Key
  static const String geminiApiKey = 'YOUR_GEMINI_API_KEY';
  
  // ============ Firebase ============
  
  /// FCM Server Key（用于后端发送推送）
  static const String fcmServerKey = 'YOUR_FCM_SERVER_KEY';
  
  // ============ 支付 ============
  
  /// 微信支付 App ID
  static const String wechatAppId = 'YOUR_WECHAT_APP_ID';
  
  /// 支付宝 App ID
  static const String alipayAppId = 'YOUR_ALIPAY_APP_ID';
}
