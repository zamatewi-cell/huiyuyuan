# ============================================================
# huiyuanyuan v4.0 environment template
# Copy to .env and fill in real values: cp .env.example .env
# Do not commit the real .env file to git.
# ============================================================

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql://huyy_user:YOUR_STRONG_PASSWORD@localhost:5432/huiyuanyuan

# Cache (Redis 6+)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# JWT authentication
JWT_SECRET_KEY=CHANGE_ME_REQUIRED
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# Aliyun SMS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=YOUR_SMS_SIGN_NAME
SMS_TEMPLATE_CODE=

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=huiyuanyuan-images
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# AI service
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus-latest

# Application settings
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://xn--lsws2cdzg.top,https://www.xn--lsws2cdzg.top
LOG_LEVEL=INFO

# Backup
BACKUP_DIR=/opt/huiyuanyuan/backups
BACKUP_RETENTION_DAYS=7

# Monitoring
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
