# ============================================================
# 汇玉源 v4.0 — 环境变量配置模板
# 复制为 .env 并填入真实值: cp .env.example .env
# !! .env 文件不要提交到 Git !!
# ============================================================

# ============ 数据库 (PostgreSQL 15+) ============
# server_setup.sh 自动生成密码，手动修改请同步 PostgreSQL
DATABASE_URL=postgresql://huyy_user:YOUR_STRONG_PASSWORD@localhost:5432/huiyuanyuan

# ============ 缓存 (Redis 6+) ============
# 格式: redis://:PASSWORD@host:port/db
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ============ JWT 认证 (必填！无值将拒绝启动) ============
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_REQUIRED
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# ============ 阿里云短信 ============
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=汇玉源
SMS_TEMPLATE_CODE=

# ============ 阿里云 OSS ============
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=huiyuanyuan-images
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# ============ AI 服务 ============
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_SITE_URL=https://huiyuanyuan.local
OPENROUTER_APP_NAME=汇玉源

# ============ 应用配置 ============
APP_ENV=production
DEBUG=false
# CORS 白名单，逗号分隔; 禁止使用 * !!
ALLOWED_ORIGINS=http://47.112.98.191
LOG_LEVEL=INFO

# ============ 备份配置 ============
BACKUP_DIR=/opt/huiyuanyuan/backups
BACKUP_RETENTION_DAYS=7

# ============ 监控 (可选) ============
# 钉钉机器人 Webhook (告警通知)
DINGTALK_WEBHOOK=
# 企业微信机器人 Webhook
WECHAT_WEBHOOK=
