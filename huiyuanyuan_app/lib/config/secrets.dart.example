library;

/// Example only. Inject secrets with --dart-define instead of committing them.
class Secrets {
  static const String dashScopeApiKey = String.fromEnvironment(
    'DASHSCOPE_API_KEY',
    defaultValue: '',
  );

  // Legacy fallback during migration.
  static const String openRouterApiKey = String.fromEnvironment(
    'OPENROUTER_API_KEY',
    defaultValue: '',
  );

  static const String ossAccessKeyId = String.fromEnvironment(
    'OSS_ACCESS_KEY_ID',
    defaultValue: '',
  );

  static const String ossAccessKeySecret = String.fromEnvironment(
    'OSS_ACCESS_KEY_SECRET',
    defaultValue: '',
  );

  static const String fcmServerKey = String.fromEnvironment(
    'FCM_SERVER_KEY',
    defaultValue: '',
  );

  static const String wechatAppId = String.fromEnvironment(
    'WECHAT_APP_ID',
    defaultValue: '',
  );

  static const String alipayAppId = String.fromEnvironment(
    'ALIPAY_APP_ID',
    defaultValue: '',
  );
}
