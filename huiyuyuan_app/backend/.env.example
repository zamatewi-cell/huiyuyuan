# ============================================================
# huiyuyuan v4.0 environment template
# Copy to .env and fill in real values: cp .env.example .env
# Do not commit the real .env file to git.
# ============================================================

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql://huyy_user:YOUR_STRONG_PASSWORD@localhost:5432/huiyuyuan

# Cache (Redis 6+)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# JWT authentication
JWT_SECRET_KEY=CHANGE_ME_REQUIRED
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# Aliyun SMS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=YOUR_SMS_SIGN_NAME
SMS_TEMPLATE_CODE=

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=huiyuyuan-images
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# AI service
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus-latest

# Application settings
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://xn--lsws2cdzg.top,https://www.xn--lsws2cdzg.top
ALLOWED_HOSTS=xn--lsws2cdzg.top,www.xn--lsws2cdzg.top
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_CREDENTIAL_FAILURE_LIMIT=8
LOGIN_IP_FAILURE_LIMIT=20
APP_LATEST_VERSION=3.0.3
APP_LATEST_BUILD_NUMBER=5
APP_MIN_SUPPORTED_BUILD_NUMBER=2
APP_FORCE_UPDATE=false
APP_RELEASE_NOTES=修复登录页、设置页与个人中心的翻译key泄漏|修复英文模式下的导航、订单与商城混语显示|验证码弹窗支持一键复制到剪贴板
APP_RELEASED_AT=2026-04-03T17:10:00+08:00
APP_ANDROID_DOWNLOAD_URL=https://xn--lsws2cdzg.top/downloads/huiyuyuan-latest.apk
APP_IOS_DOWNLOAD_URL=
APP_WEB_DOWNLOAD_URL=https://xn--lsws2cdzg.top
LOG_LEVEL=INFO

# Backup
BACKUP_DIR=/opt/huiyuyuan/backups
BACKUP_RETENTION_DAYS=7

# Monitoring
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
