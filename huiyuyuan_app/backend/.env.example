# ============================================================
# huiyuyuan v4.0 environment template
# Copy to .env and fill in real values: cp .env.example .env
# Do not commit the real .env file to git.
# ============================================================

# Database (PostgreSQL 15+)
DATABASE_URL=postgresql://huyy_user:YOUR_STRONG_PASSWORD@localhost:5432/huiyuyuan

# Cache (Redis 6+)
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# JWT authentication
JWT_SECRET_KEY=CHANGE_ME_REQUIRED
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_DAYS=7

# Aliyun SMS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=YOUR_SMS_SIGN_NAME
SMS_TEMPLATE_CODE=

# Aliyun OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=huiyuyuan-images
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# AI service
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VISION_MODEL=qwen-vl-plus-latest

# Application settings
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://xn--lsws2cdzg.top,https://www.xn--lsws2cdzg.top
ALLOWED_HOSTS=xn--lsws2cdzg.top,www.xn--lsws2cdzg.top
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_CREDENTIAL_FAILURE_LIMIT=8
LOGIN_IP_FAILURE_LIMIT=20
APP_LATEST_VERSION=3.0.4
APP_LATEST_BUILD_NUMBER=6
APP_MIN_SUPPORTED_BUILD_NUMBER=2
APP_FORCE_UPDATE=false
APP_RELEASE_NOTES=管理员支持自定义角色模板保存、重命名与删除，整理权限更高效|新增独立支付对账工作台，确认到账与异常标记可按权限拆分授权|继续收紧管理员与操作员权限边界，并修复对账相关中英文混用文案
APP_RELEASED_AT=2026-04-16T11:10:00+08:00
APP_ANDROID_DOWNLOAD_URL=https://xn--lsws2cdzg.top/downloads/huiyuyuan-latest.apk
# Optional mirror list for Android update downloads, split by "|".
# Example:
# APP_ANDROID_DOWNLOAD_URLS=https://xn--lsws2cdzg.top/downloads/huiyuyuan-latest.apk|https://your-oss-domain.example.com/huiyuyuan-latest.apk
APP_ANDROID_DOWNLOAD_URLS=
APP_ANDROID_DOWNLOAD_FILE_PATH=/var/www/huiyuyuan/downloads/huiyuyuan-latest.apk
APP_ANDROID_DOWNLOAD_CONTENT_TYPE=application/vnd.android.package-archive
# Optional overrides. Leave blank to let the backend compute size/hash from APP_ANDROID_DOWNLOAD_FILE_PATH.
APP_ANDROID_DOWNLOAD_SIZE_BYTES=
APP_ANDROID_DOWNLOAD_SHA256=
APP_IOS_DOWNLOAD_URL=
APP_WEB_DOWNLOAD_URL=https://xn--lsws2cdzg.top
LOG_LEVEL=INFO

# Backup
BACKUP_DIR=/opt/huiyuyuan/backups
BACKUP_RETENTION_DAYS=7

# Monitoring
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
