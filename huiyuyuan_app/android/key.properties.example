# Android 签名配置模板
# 1. 复制本文件为 key.properties（不要提交到 Git）
#    copy key.properties.example key.properties
# 2. 填入你的 keystore 信息
# 3. 生成 keystore 命令：
#    keytool -genkeypair -v -keystore huiyuyuan.jks -keyalg RSA -keysize 2048 -validity 10000 -alias huiyuyuan
#
# 重要：huiyuyuan.jks 和 key.properties 均已加入 .gitignore，切勿提交。

storePassword=your_store_password
keyPassword=your_key_password
keyAlias=huiyuyuan
storeFile=../huiyuyuan.jks
